# name: test/sql/cityjson.test
# description: Test read_cityjson table function
# group: [sql]

require cityjson

# Test basic CityJSON reading
statement ok
CREATE TABLE buildings AS SELECT * FROM read_cityjson('test/data/minimal.city.json');

# Verify the table was created
query I
SELECT COUNT(*) FROM buildings;
----
1

# Check that we have the expected columns
query I
SELECT COUNT(*) FROM (SELECT * FROM buildings LIMIT 0);
----
0

# Test feature_id column - for CityJSON, feature_id is the root object ID
query I
SELECT COUNT(*) FROM buildings WHERE feature_id IS NOT NULL;
----
1

# Test feature_id is the CityObject ID (not the file path)
query T
SELECT feature_id FROM buildings;
----
building1

# Test object_type column
query T
SELECT object_type FROM buildings;
----
Building

# Test attribute column (yearOfConstruction)
query I
SELECT yearOfConstruction FROM buildings;
----
2020

# Test CityJSONSeq format
statement ok
CREATE TABLE buildings_seq AS SELECT * FROM read_cityjson('test/data/sample.city.jsonl');

# Verify we got 2 buildings from the sequence file
query I
SELECT COUNT(*) FROM buildings_seq;
----
2

# Test that both buildings have the correct type
query I
SELECT COUNT(*) FROM buildings_seq WHERE object_type = 'Building';
----
2

# Test CityJSON with parent/child grouping (CityJSONFeature spec)
statement ok
CREATE TABLE buildings_parts AS SELECT * FROM read_cityjson('test/data/building_with_parts.city.json');

# building1 has 2 children (building1-part1, building1-part2), building2 is standalone = 4 objects total
query I
SELECT COUNT(*) FROM buildings_parts;
----
4

# building1 and its parts should have feature_id = 'building1'
query I
SELECT COUNT(*) FROM buildings_parts WHERE feature_id = 'building1';
----
3

# building2 is standalone, feature_id = 'building2'
query I
SELECT COUNT(*) FROM buildings_parts WHERE feature_id = 'building2';
----
1

# Clean up
statement ok
DROP TABLE buildings;

statement ok
DROP TABLE buildings_seq;

statement ok
DROP TABLE buildings_parts;
